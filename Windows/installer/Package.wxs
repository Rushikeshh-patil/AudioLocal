<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="AudioLocal for Windows"
    Manufacturer="Rushikesh Patil"
    Version="$(var.InstallerVersion)"
    UpgradeCode="706A4702-A83B-4121-AFF5-3B53C51C8E61"
    Language="1033"
    Scope="perMachine"
    InstallerVersion="500">

    <SummaryInformation Description="AudioLocal for Windows" Manufacturer="Rushikesh Patil" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <Launch Condition="VersionNT64" Message="AudioLocal for Windows requires a 64-bit edition of Windows." />

    <Feature Id="MainFeature" Title="AudioLocal for Windows" Level="1">
      <ComponentGroupRef Id="PublishedApplicationFiles" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AudioLocalProgramMenuFolder" Name="AudioLocal" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcutComponent" Directory="AudioLocalProgramMenuFolder" Guid="*">
      <Shortcut
        Id="AudioLocalStartMenuShortcut"
        Name="AudioLocal for Windows"
        Description="Launch AudioLocal for Windows"
        Target="[INSTALLFOLDER]AudioLocal.Windows.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="AudioLocalProgramMenuFolderOnUninstall" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\AudioLocal" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
